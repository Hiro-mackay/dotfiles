# Codex CLI runtime data — never enters git.
# Tracked in this repo: AGENTS.md, config.toml, agents/, script/, .gitignore.
# Everything else lives here as runtime state.

# Authentication / secrets — defense in depth: cover variants and editor noise
auth.json
*.pem
*.key
*.env
.env*
credentials*
token*
id_rsa*
id_ed25519*

# Editor swap / backup files (could capture secret content mid-edit)
*~
*.bak
*.swp
*.swo
.*.sw?
\#*\#
.\#*

# SQLite databases (logs, state) and WAL/SHM sidecars
*.sqlite
*.sqlite-*
*.db
*.db-*
*.sqlite3*

# Session and history
sessions/
session_index.jsonl
history.jsonl

# Caches and ephemeral state
cache/
log/
tmp/
.tmp/
shell_snapshots/
memories/
models_cache.json
installation_id
version.json
.personality_migration

# Generated by bootstrap.sh from Claude skills+rules
skills/

# macOS
.DS_Store
