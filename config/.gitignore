# .gitignore
# Ignore All
*
!*/

# Allowlist
!.gitignore
!brew/*
!zsh/.zshenv
!zsh/.zshrc
!zsh/rc.d/**
!zsh/README.md
!bttpreset/*
!git/*
!git/hooks/**
!karabiner/karabiner.json
!vscode/*
!mise/*
!gh/config.yml
!claude/settings.json
!claude/script/**
!claude/.gitignore
!claude/CLAUDE.md
!claude/README.md
!claude/agents/**
# Shared SSoT for skills + AGENTS.md (projected into claude/codex by bootstrap).
# claude/skills and codex/skills are regenerated symlinks -> not tracked.
!agents/**
# SECURITY: codex/auth.json (OAuth credentials) lives under config/codex/.
# Never add `!codex/**` — it would expose secrets. Allowlist only specific paths.
!codex/.gitignore
!codex/AGENTS.md
!codex/README.md
!codex/config.toml
!codex/agents/**
!codex/script/**
