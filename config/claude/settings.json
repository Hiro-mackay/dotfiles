{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(pkill:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(git worktree:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git show:*)",
      "Bash(git fetch:*)",
      "Bash(git commit:*)",
      "Bash(brew:*)",
      "Bash(go:*)",
      "Bash(docker:*)",
      "Bash(stow:*)",
      "Bash(which:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(chmod:*)",
      "Bash(gh:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(bun:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(git reset:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git rebase:*)",
      "Bash(git clean:*)",
      "Bash(rm -rf:*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Write(**/secrets/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Reminder: Respond in Japanese when user writes Japanese. Conventional commits. Run /verify before committing. Keep files under 300 lines. Default to team for multi-file changes. Read ~/.claude/skills/team-conventions/SKILL.md before creating teams.'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -n --arg cwd \"$(pwd)\" '{\"cwd\":$cwd,\"notification_type\":\"stop\"}' | ~/.claude/script/notify.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/script/notify.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/script/hooks/detect-console-log.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/script/hooks/go-vet.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/script/hooks/block-dev-server.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/script/statusline.sh"
  },
  "enabledPlugins": {
    "hookify@claude-code-plugins": true,
    "commit-commands@claude-code-plugins": true,
    "context7-plugin@context7-marketplace": true,
    "security-guidance@claude-code-plugins": true
  },
  "skipDangerousModePermissionPrompt": true
}