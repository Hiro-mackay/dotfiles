#!/usr/bin/env zsh
#
# Sanitize Codex's config.toml in the index before it lands in a commit.
# The working tree copy is left alone so Codex keeps reading its full state.
#
# To bypass (e.g. when intentionally landing the full file): git commit --no-verify

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
TARGET="config/codex/config.toml"
SANITIZER="${REPO_ROOT}/config/git/hooks/sanitize-codex-config.awk"

# Skip when the file is not tracked in the index at all (e.g. fresh clone
# before the first commit, or the file was deliberately removed).
staged_blob="$(git ls-files -s "${TARGET}" 2>/dev/null | awk '{print $2}')"
if [[ -z "${staged_blob}" ]]; then
    exit 0
fi

if [[ ! -r "${SANITIZER}" ]]; then
    echo "pre-commit: sanitizer not found at ${SANITIZER}" >&2
    exit 1
fi

# Pipe through awk to preserve trailing newline behavior; capturing via $(...)
# would strip the final newline.
sanitized_blob="$(git show ":${TARGET}" | awk -f "${SANITIZER}" | git hash-object -w --stdin)"

if [[ "${staged_blob}" == "${sanitized_blob}" ]]; then
    exit 0
fi

git update-index --cacheinfo "100644,${sanitized_blob},${TARGET}"
echo "pre-commit: sanitized ${TARGET} (runtime state stripped from commit; working tree untouched)"

# --- rulesync drift check (rules layer) ---
# When the rules source or the generated global files are staged, ensure
# CLAUDE.md / AGENTS.md still match .rulesync/. Catches the case where the
# generated file was hand-edited and drifted from its single source.
rules_touched="$(git diff --cached --name-only -- '.rulesync/' 'config/claude/CLAUDE.md' 'config/codex/AGENTS.md' 2>/dev/null)"
if [[ -n "${rules_touched}" ]]; then
    if command -v rulesync >/dev/null 2>&1; then
        RULESYNC="rulesync"
    elif command -v mise >/dev/null 2>&1 && mise which rulesync >/dev/null 2>&1; then
        RULESYNC="mise exec -- rulesync"
    else
        RULESYNC=""
        echo "pre-commit: rulesync not found; skipping rules drift check (install: mise install)" >&2
    fi
    if [[ -n "${RULESYNC}" ]]; then
        if ! ${=RULESYNC} generate -g --targets claudecode,codexcli --features rules \
            --input-root "${REPO_ROOT}" --check >/dev/null 2>&1; then
            echo "pre-commit: CLAUDE.md / AGENTS.md are out of date with .rulesync/." >&2
            echo "  fix: rulesync generate -g --targets claudecode,codexcli --features rules --input-root ${REPO_ROOT}" >&2
            echo "  then 'git add' the regenerated files. (bypass: git commit --no-verify)" >&2
            exit 1
        fi
    fi
fi
